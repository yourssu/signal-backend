# ===============================
# Monorepo root
# ===============================
.env
.env.*
!.env.example

# ===============================
# app/ — Java / Spring Boot / Gradle
# ===============================
app/.gradle/
app/build/
app/out/
app/bin/

# Local-only Spring config (contains secrets)
app/src/main/resources/application-local.yml
app/src/main/resources/application-local.properties

# IntelliJ HTTP client env (contains access keys)
app/src/main/resources/http/http-client.env.json

# IDE
.idea/
*.iws
*.iml
*.ipr

# Spring Boot
HELP.md

# ===============================
# observer/ — Python
# ===============================
observer/.env
observer/.env.*
!observer/.env.example
observer/env/
observer/__pycache__/
observer/**/__pycache__/
observer/*.pyc
observer/**/*.pyc
observer/logs/
observer/.idea/

# ===============================
# OS
# ===============================
.DS_Store
Thumbs.db
