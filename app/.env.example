# Spring profile
SPRING_PROFILES_ACTIVE=local

# Database (local uses H2 in-memory, no config needed)

# Admin
ADMIN_ACCESS_KEY=your-admin-access-key
CONTACT_SECRET_KEY=your-contact-secret-key

# JWT
JWT_SECRET=your-jwt-secret-minimum-256-bits-long-string-here

# KakaoPay
KAKAOPAY_ADMIN_KEY=your-kakaopay-admin-key
KAKAOPAY_CID=TC0ONETIME
KAKAOPAY_APPROVAL_URL=http://localhost:8080/purchase/success
KAKAOPAY_CANCEL_URL=http://localhost:8080/purchase/cancel
KAKAOPAY_FAIL_URL=http://localhost:8080/purchase/fail

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROMPT=your-prompt-here
USER_INPUT_LIMIT=100

# Ticket policy
TICKET_PRICE_POLICY=single@1000n1.small@3000n4.best@5000n8
TICKET_PRICE_REGISTERED_POLICY=single@700n1.small@2100n4.best@3500n8

# Banned words (comma-separated)
BANNED_WORDS=욕설1,욕설2,욕설3
