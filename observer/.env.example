# Runtime environment
ENVIRONMENT=dev

# Slack
SLACK_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#signal-channel
SLACK_ADMIN_CHANNEL=#signal-admin-channel
SLACK_LOG_CHANNEL=#signal-log-channel

# Bank account for ticket payment instructions
BANK_NAME=카카오뱅크
BANK_ACCOUNT=your-account-number

# Ticket price policy (from Spring server config)
TICKET_PRICE_POLICY=single@1000n1.small@3000n4.best@5000n8
TICKET_PRICE_REGISTERED_POLICY=single@700n1.small@2100n4.best@3500n8

# Signal server
SERVER_PORT=9012
ADMIN_ACCESS_KEY=your-admin-access-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_URL=https://api.openai.com/v1/responses
OPENAI_POLICY_PROMPT=your-policy-prompt
